# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# --- Google OAuth ("Continue with Google") ---
# OAuth client credentials from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <APP_URL>/api/auth/callback/google
# (e.g. http://localhost:3000/api/auth/callback/google for local dev)
AUTH_GOOGLE_ID=****
AUTH_GOOGLE_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# --- Stripe (Phase 2: subscriptions) ---
# Secret key from https://dashboard.stripe.com/apikeys (use the TEST key while building)
STRIPE_SECRET_KEY=****
# Webhook signing secret. Locally this comes from `stripe listen`; in production
# it's the signing secret of the webhook endpoint you register in the dashboard.
STRIPE_WEBHOOK_SECRET=****
# Recurring Price ids for each plan (created in the Stripe dashboard).
STRIPE_PRICE_BASIC=****
STRIPE_PRICE_PRO=****
# Public base URL of this app (used for Stripe success/cancel/return links and
# for the verification / password-reset links emailed to users).
# e.g. https://chadchat-xxxx.vercel.app  (no trailing slash)
NEXT_PUBLIC_APP_URL=****

# --- Email (Resend): account verification + password reset ---
# API key from https://resend.com/api-keys. Until this is set, the app runs
# fine but verification / reset emails are skipped (logged in dev).
RESEND_API_KEY=****
# From address. Must be on a domain you've verified in Resend. Before verifying
# a domain you can use Resend's onboarding sender: "Chad <onboarding@resend.dev>"
EMAIL_FROM=****

# --- Admin panel ---
# Comma-separated allowlist of admin emails (must match how you sign in).
ADMIN_EMAILS=****
# Passphrase for the admin panel (NAV-34) — a second lock on top of the email
# allowlist and the obscure URL. Admins must type this to open the panel. Use a
# strong, random value in production; the panel stays locked until it's set.
ADMIN_PANEL_SECRET=****
